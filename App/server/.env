# Railway injects DATABASE_URL automatically once you attach a Postgres
# plugin to this service — you don't need to set it by hand in production.
# For local/TRAE IDE use, point this at a local Postgres or a Railway
# instance's public connection string (see README for how to get one).
DATABASE_URL=postgresql://postgres:dIaPfXJRKxCUnHdBXEOrRNoYifEsXxND@hayabusa.proxy.rlwy.net:33919/railway

# Railway injects PORT automatically too; this is just for local dev.
PORT=3000

# Required. Any long random string — used to sign login tokens.
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=3yV8hb5XpQuKBdtUeiwlR04Lvmr9jP2qsncoDzAHTIWCfY1EMxZOSF7kJN6gaG

# Optional — the admin area uses ONE shared password (like the original
# app). Leave these unset and it defaults to:
#   email:    admin@vertadelivery.com
#   password: 1Nigeria@
# Override here (or in Railway's Variables tab) if you want a different
# password. The admin account is created automatically on first boot.
ADMIN_EMAIL=admin@vertadelivery.com
ADMIN_PASSWORD=1Nigeria@

# Restored delete confirmation password (bulk order delete + expense delete).
DELETE_PASSWORD=SKY

# --- WhatsApp/SMS order notifications (Twilio) ---
# Leave these blank/unset and notifications are simply skipped — nothing
# else in the app depends on them. Fill in once you have a Twilio account.
# See README.md → "Setting up WhatsApp/SMS notifications" for full steps.
TWILIO_ACCOUNT_SID=AC47c594b893bf69825b9f46db6767e265
TWILIO_AUTH_TOKEN=dc09d1959e231b67a5b8e74e4c7c02c7
TWILIO_FROM_NUMBER=+12409161933
NOTIFY_TO_NUMBER=+231881405696
NOTIFY_CHANNEL=whatsapp
